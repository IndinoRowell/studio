rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email == "jcesperanza@neu.edu.ph") ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Users can see their own profile, admins can see all.
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isSignedIn() && isAdmin(); 
      
      // Allow registration by owner or admin
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // Allow updates by owner or admin
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // Only admins can delete profiles
      allow delete: if isAdmin();
    }

    match /visitorLogs/{logId} {
      // Allow listing if the query is filtered by the user's UID or if the user is an admin
      allow list: if isSignedIn() && (
        isAdmin() || 
        (request.query.filters.visitorId == request.auth.uid)
      );
      
      // Individual document access
      allow get: if isSignedIn() && (isAdmin() || resource.data.visitorId == request.auth.uid);
      
      // Allow creation by the visitor themselves or an admin
      allow create: if isSignedIn() && (request.resource.data.visitorId == request.auth.uid || isAdmin());
      
      // Allow updates by the visitor or an admin
      allow update: if isAdmin() || (isSignedIn() && resource.data.visitorId == request.auth.uid);
      
      // Only admins can delete logs
      allow delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      // Allow signed-in users to check their own status, or admins to check anyone.
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      
      // Only existing admins can list administrators.
      allow list: if isAdmin();
      
      // Initial bootstrap or admin management
      allow create, update, delete: if isAdmin() || (isSignedIn() && request.auth.token.email == "jcesperanza@neu.edu.ph"); 
    }
  }
}