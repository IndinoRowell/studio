rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == "jcesperanza@neu.edu.ph"
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Users can see their own profile, admins can see all.
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin(); 
      
      // Allow registration and updates by owner or admin
      allow create: if isSignedIn() && (request.auth.uid == userId);
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /visitorLogs/{logId} {
      // Allow list if the query is restricted to the user's own UID or they are an admin
      allow list: if isSignedIn() && (
        isAdmin() || 
        (resource.data.visitorId == request.auth.uid)
      );
      
      // Individual document access
      allow get: if isSignedIn() && (isAdmin() || resource.data.visitorId == request.auth.uid);
      
      // Allow creation by the visitor themselves
      allow create: if isSignedIn() && request.resource.data.visitorId == request.auth.uid;
      
      // Allow updates by the visitor or an admin
      allow update: if isAdmin() || (isSignedIn() && resource.data.visitorId == request.auth.uid);
      
      // Only admins can delete logs
      allow delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      // Allow signed-in users to check their own status, or admins to check anyone.
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      
      // Only existing admins can list administrators.
      allow list: if isAdmin();
      
      allow create, update, delete: if false; 
    }
  }
}