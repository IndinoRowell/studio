rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Base check for the system administrator
    function isSystemAdmin() {
      return isSignedIn() && request.auth.token.email == "jcesperanza@neu.edu.ph";
    }

    // General admin check including system admin and database-registered admins
    function isAdmin() {
      return isSystemAdmin() || 
        (isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Users can see their own profile, admins can see all.
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isSignedIn() && isAdmin(); 
      
      // Allow registration by owner or admin
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // Allow updates by owner or admin
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // Only admins can delete profiles
      allow delete: if isAdmin();
    }

    match /visitorLogs/{logId} {
      // Robust list rule: 
      // 1. Admins can see all records.
      // 2. Users can see their own records ONLY IF they filter by their UID.
      allow list: if isSignedIn() && (
        isAdmin() || 
        (request.query.filters.visitorId == request.auth.uid)
      );
      
      // Individual document access
      allow get: if isSignedIn() && (isAdmin() || resource.data.visitorId == request.auth.uid);
      
      // Allow creation by the visitor themselves or an admin
      allow create: if isSignedIn() && (request.resource.data.visitorId == request.auth.uid || isAdmin());
      
      // Allow updates by the visitor or an admin
      allow update: if isAdmin() || (isSignedIn() && resource.data.visitorId == request.auth.uid);
      
      // Only admins can delete logs
      allow delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      // Users can check their own admin status. System admin manages the registry.
      allow get: if isSignedIn() && (request.auth.uid == adminId || isSystemAdmin());
      allow list, create, update, delete: if isSystemAdmin(); 
    }
  }
}