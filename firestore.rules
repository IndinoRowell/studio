rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Users can see their own profile, admins can see all.
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Only admins can list the directory
      
      // Allow registration and updates by owner or admin
      allow create: if (isOwner(userId) && request.resource.data.id == userId) || isAdmin();
      allow update: if (isOwner(userId) && request.resource.data.id == resource.data.id) || isAdmin();
      allow delete: if isAdmin();
    }

    match /visitorLogs/{logId} {
      // Allow listing if the user is filtering by their own visitorId OR if they are an admin.
      // We use the 'resource.data' check which Firestore uses to validate queries.
      allow list: if isSignedIn() && (isAdmin() || resource.data.visitorId == request.auth.uid);
      
      // Allow getting a single document
      allow get: if isSignedIn() && (isAdmin() || resource.data.visitorId == request.auth.uid);
      
      // Allow creation by the visitor themselves
      allow create: if isSignedIn() && request.resource.data.visitorId == request.auth.uid;
      
      // Allow updates by the visitor or an admin
      allow update: if isAdmin() || (isSignedIn() && resource.data.visitorId == request.auth.uid);
      
      // Only admins can delete logs
      allow delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      // Allow any signed-in user to check their own administrative status.
      allow get: if isSignedIn() && request.auth.uid == adminId;
      
      // Only existing admins can list administrators.
      allow list: if isAdmin();
      
      allow create, update, delete: if false; 
    }
  }
}