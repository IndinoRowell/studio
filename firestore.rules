
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Users can see their own profile, admins can see all.
      allow get: if isOwner(userId) || isAdmin();
      
      // Allow listing. Non-admins must filter by their own ID if they were to list (not common for users).
      allow list: if isSignedIn() && (isAdmin() || (request.query.limit <= 10 && userId == request.auth.uid));
      
      allow create: if (isOwner(userId) && request.resource.data.id == userId) || isAdmin();
      allow update: if (isOwner(userId) && request.resource.data.id == resource.data.id) || isAdmin();
      allow delete: if isAdmin();
    }

    match /visitorLogs/{visitorLogId} {
      // Allow users to get their own logs, and admins to get any log.
      // We use 'read' to cover both 'get' and 'list'.
      allow read: if isSignedIn() && (isAdmin() || resource.data.visitorId == request.auth.uid);
      
      // Explicitly allow listing for signed-in users. 
      // Firestore enforces that the query must be filtered by visitorId for non-admins.
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && request.resource.data.visitorId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.visitorId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      // Allow any signed-in user to check their own administrative status.
      allow get: if isSignedIn() && request.auth.uid == adminId;
      
      // Only existing admins can list administrators.
      allow list: if isAdmin();
      
      allow create, update, delete: if false; 
    }
  }
}
