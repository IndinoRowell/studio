rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Direct check for System Admin email to avoid recursive exists checks
    function isSystemAdmin() {
      return isSignedIn() && request.auth.token.email == "jcesperanza@neu.edu.ph";
    }

    // Role-based admin check
    function isAdmin() {
      return isSystemAdmin() || 
        (isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
    }

    // --- User Profile Rules ---
    match /users/{userId} {
      // Users can access their own profile
      allow get: if isSignedIn() && request.auth.uid == userId;
      
      // Administrators have full control over user records
      allow get, list, create, update, delete: if isAdmin();

      // Individual user write operations for onboarding/profile management
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Visitor Log Rules ---
    match /visitorLogs/{logId} {
      // Individuals can list and get their own specific logs
      // The 'list' rule with resource.data automatically validates query filters
      allow list: if isSignedIn() && resource.data.visitorId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.visitorId == request.auth.uid;
      
      // Administrators have full access to view and manage all logs
      allow list, get, create, update, delete: if isAdmin();
      
      // Allow signed-in users to record their own check-ins
      allow create: if isSignedIn() && request.resource.data.visitorId == request.auth.uid;
    }

    // --- Admin Registry Rules ---
    match /roles_admin/{adminId} {
      // Any signed-in user can check their own entry to verify admin status
      allow get: if isSignedIn() && request.auth.uid == adminId;
      
      // Only the primary System Admin can modify the administrator list
      allow list, create, update, delete: if isSystemAdmin();
    }
  }
}