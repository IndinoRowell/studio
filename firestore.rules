
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isOwner(userId) || isAdmin();
      allow create: if (isOwner(userId) && request.resource.data.id == userId) || isAdmin();
      allow update: if (isOwner(userId) && request.resource.data.id == resource.data.id) || isAdmin();
      allow delete: if isAdmin();
    }

    match /visitorLogs/{visitorLogId} {
      // Allow users to get their own logs, and admins to get any log
      allow get: if isAdmin() || (isSignedIn() && resource.data.visitorId == request.auth.uid);
      
      // Allow listing. Firestore will enforce that non-admins must filter queries 
      // by their own visitorId to match the individual document access rules.
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && request.resource.data.visitorId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.visitorId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      // CRITICAL: Allow any signed-in user to check their own administrative status.
      // This prevents the permission error during the initial role verification.
      allow get: if isSignedIn() && request.auth.uid == adminId;
      
      // Only existing admins can list the entire directory of administrators.
      allow list: if isAdmin();
      
      allow create, update, delete: if false; 
    }
  }
}
