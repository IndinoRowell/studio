rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Check for hardcoded system administrator email
    function isSystemAdmin() {
      return isSignedIn() && request.auth.token.email == "jcesperanza@neu.edu.ph";
    }

    // General admin check: system admin OR registered in roles_admin collection
    function isAdmin() {
      return isSystemAdmin() || 
        (isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
    }

    // --- User Profile Rules ---
    match /users/{userId} {
      // Individuals can access their own profile
      allow get: if isSignedIn() && request.auth.uid == userId;
      
      // Admins have full access to the directory
      allow get, list, create, update, delete: if isAdmin();

      // Allow users to create their own profile during registration
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Visitor Log Rules ---
    match /visitorLogs/{logId} {
      // SEPARATED USER PRIVILEGE: Individuals can list their own logs if filtered by their UID
      allow list: if isSignedIn() && request.query.filters.visitorId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.visitorId == request.auth.uid;
      
      // SEPARATED ADMIN PRIVILEGE: Admins can list and access ALL records without restriction
      allow list, get, create, update, delete: if isAdmin();
      
      // Allow users to create their own log entries
      allow create: if isSignedIn() && request.resource.data.visitorId == request.auth.uid;
    }

    // --- Admin Registry Rules ---
    match /roles_admin/{adminId} {
      // Users can check their own administrative status
      allow get: if isSignedIn() && request.auth.uid == adminId;
      
      // Only the System Admin (hardcoded) can manage the admin registry
      allow list, create, update, delete: if isSystemAdmin();
    }
  }
}