
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a library member (Student, Faculty, or Staff).",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique identifier, matching the Firebase Auth UID."
        },
        "displayName": {
          "type": "string",
          "description": "Full name of the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "University email address."
        },
        "college": {
          "type": "string",
          "description": "College or department affiliation."
        },
        "role": {
          "type": "string",
          "enum": ["Student", "Faculty", "Staff"],
          "description": "User's role within the university."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the profile was created."
        }
      },
      "required": ["id", "email", "role"]
    },
    "VisitorLog": {
      "title": "VisitorLog",
      "description": "A record of a single library visit.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique log ID."
        },
        "visitorId": {
          "type": "string",
          "description": "The UID of the visitor."
        },
        "name": {
          "type": "string",
          "description": "Name of the visitor at the time of check-in."
        },
        "reason": {
          "type": "string",
          "description": "Reason for the visit (e.g., Study, Research)."
        },
        "college": {
          "type": "string",
          "description": "College affiliation at the time of check-in."
        },
        "employeeStatus": {
          "type": "string",
          "description": "Status (Student, Faculty, Staff)."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Date and time of check-in."
        }
      },
      "required": ["visitorId", "reason", "college", "employeeStatus", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles. Access is restricted to the owner or admins."
    },
    "/visitorLogs/{logId}": {
      "schema": "VisitorLog",
      "description": "Stores library check-in records."
    },
    "/roles_admin/{adminId}": {
      "schema": "User",
      "description": "Registry for administrative access."
    }
  }
}
